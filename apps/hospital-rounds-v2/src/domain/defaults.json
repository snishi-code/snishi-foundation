{
  "_comment": "アプリの初期値。ユーザーが何も触らずに保存ボタンを押した状態 = この JSON。プログラム内にベタ打ちせずここに集約してメンテナンスしやすくする。Phase 7: problem / S / O / A / P / shared の6パネルすべてをフォーマットで扱う。",

  "formats": [
    {
      "name": "プロブレムリスト",
      "panel": "problem",
      "joiner": "\n",
      "labelSep": "",
      "titleWrap": "",
      "tags": [],
      "items": [
        { "label": "#", "kind": "number", "unit": "" },
        { "label": "#", "kind": "number", "unit": "" },
        { "label": "#", "kind": "number", "unit": "" },
        { "label": "#", "kind": "number", "unit": "" },
        { "label": "#", "kind": "number", "unit": "" },
        { "label": "", "kind": "text", "normal": "" }
      ]
    },
    {
      "name": "自覚症状",
      "panel": "S",
      "joiner": ", ",
      "labelSep": "：",
      "titleWrap": "",
      "tags": [],
      "items": [
        { "label": "", "kind": "text", "normal": "特に新しい訴えなし" }
      ]
    },
    {
      "name": "バイタル",
      "panel": "O",
      "joiner": ", ",
      "labelSep": " ",
      "titleWrap": "（）",
      "tags": [],
      "items": [
        { "label": "BP",   "kind": "fraction", "unit": "mmHg", "fracMode": "numeric" },
        { "label": "P",    "kind": "number",   "unit": "bpm"  },
        { "label": "SpO2", "kind": "number",   "unit": "%"    },
        { "label": "RR",   "kind": "number",   "unit": ""     },
        { "label": "T",    "kind": "number",   "unit": "℃"   }
      ]
    },
    {
      "name": "身体所見",
      "panel": "O",
      "joiner": "\n",
      "labelSep": "：",
      "titleWrap": "（）",
      "tags": [],
      "items": [
        { "label": "General",  "kind": "text", "normal": "良好" },
        { "label": "肺音",     "kind": "text", "normal": "明らかなラ音なし" },
        { "label": "腸音",     "kind": "text", "normal": "正常" },
        { "label": "腹部",     "kind": "text", "normal": "平坦軟、圧痛なし" },
        { "label": "食事",     "kind": "text", "normal": "摂取良好" },
        { "label": "排泄",     "kind": "text", "normal": "尿・便ともに特記なし" }
      ]
    },
    {
      "name": "所見",
      "panel": "O",
      "joiner": ", ",
      "labelSep": "：",
      "titleWrap": "",
      "tags": [],
      "_backfillAlways": true,
      "items": [
        { "label": "", "kind": "text", "normal": "特記すべき異常なし" }
      ]
    },
    {
      "name": "評価",
      "panel": "A",
      "joiner": ", ",
      "labelSep": "：",
      "titleWrap": "",
      "tags": [],
      "items": [
        { "label": "", "kind": "text", "normal": "全身状態は安定" }
      ]
    },
    {
      "name": "方針",
      "panel": "P",
      "joiner": ", ",
      "labelSep": "：",
      "titleWrap": "",
      "tags": [],
      "items": [
        { "label": "", "kind": "text", "normal": "現治療を継続" }
      ]
    },
    {
      "name": "共有",
      "panel": "shared",
      "joiner": "\n",
      "labelSep": "：",
      "titleWrap": "",
      "tags": [],
      "items": [
        { "label": "", "kind": "text", "normal": "" }
      ]
    }
  ],

  "_formatGroups_comment": "起動時に必ず 1 つ存在するデフォルトグループ。formatIndexes は上の formats 配列への index 参照 (ID は実行時生成のため index で束ねる)。Phase 7: 6パネル (problem/S/O/A/P/shared) の既定フォーマットを expandFormatIndexes に入れ、患者画面に常時タップ可能なカードとして出す。defaultFormatIndexes (旧: 空欄補完の規定文) は未使用 (空のまま)。",
  "formatGroups": [
    {
      "name": "標準",
      "isDefault": true,
      "formatIndexes": [0, 1, 2, 3, 4, 5, 6, 7],
      "defaultFormatIndexes": [],
      "expandFormatIndexes": [0, 1, 2, 3, 4, 5, 6, 7]
    }
  ],

  "clearTargets": {
    "problem": false,
    "S": true,
    "O": true,
    "A": false,
    "P": false,
    "shared": false,
    "statusYellow": true,
    "statusGreen": true,
    "statusGray": true,
    "statusBlue": false
  },

  "tags": [],

  "deviceId": "",

  "_app": {
    "patientCount": 50
  }
